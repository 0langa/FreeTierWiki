{
  "name": "free-tier-atlas",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run search:index && next build",
    "export": "node -e \"console.warn('`next export` is unnecessary with `output: \\\"export\\\"`. Run `npm run build` instead.')\"",
    "build:static": "npm run build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "search:index": "node scripts/build-search-index.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:content:all": "node scripts/validate-content.mjs content",
    "validate:content:all:list": "node scripts/validate-content.mjs content --list all_free_services_batched.md",
    "ai:launch": "node scripts/ai/launch-batch.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@mdx-js/react": "^3.1.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.542.0",
    "next": "^15.5.15",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.22",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "wrangler": "^4.39.0"
  }
}
